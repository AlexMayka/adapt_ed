# ENV
APP_VERSION=1.0.0
APP_INSTANCE=local
APP_TYPE=dev

# APP
APP_SERVICE=backend_adapt_ed
APP_HOST=localhost
APP_PORT=8000
APP_SECRET='secret'

# LOG
APP_IS_LOGGING=true
APP_LOG_LEVEL=info

# POSTGRES
PG_USER=adapt_ed
PG_PASSWORD='123'
PG_HOST=localhost
PG_PORT=5433
PG_DB=adapt_ed

PG_MAX_CONNS=20
PG_MIN_CONNS=5
PG_CONN_LIFETIME=60s
PG_CONN_IDLE_TIME=60s
PG_QUERY_TIMEOUT=60s
PG_HEALTH_CHECK_PERIOD=30s
PG_PING_TIMEOUT=5s
PG_SSL_MODE=disable

# MINIO — пустой MINIO_HOST
MINIO_USER=adapt_ed
MINIO_PASSWORD='123'
MINIO_HOST=
MINIO_PORT_API=9000
MINIO_BUCKET=adapt_ed
MINIO_USE_SSL=false

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD='123'
REDIS_DB=0
REDIS_USE_SSL=false
